#include <stdint.h>

#include "sleep.h"
#include "xil_printf.h"
#include "xparameters.h"

int main() {
	init();

    int counter = 0;
    int run_flag = 0;
    uint32_t fnd_digit, fnd_data = 0;

    while (1) {
        // xil_printf("CR: 0x%X, IDR: 0x%X\r\n", GPIOA_CR, GPIOA_IDR);
        if (GPIOA_IDR & (1 << 0)) {
            run_flag = 1;
        } else if (GPIOA_IDR & (1 << 1)) {
            run_flag = 0;
        } else if (GPIOA_IDR & (1 << 2)) {
            counter = 0;
            run_flag = 0;
        }
        for (int i = 0; i < 4; i++) {
            fnd_data = fnd_display(counter, i, &fnd_digit);
            // xil_printf("debug %d : %2x fnd_digit : %2x\r\n",counter,fnd_data,
            // fnd_digit);
            usleep(1000);
        }

        if (run_flag) {
            counter++;
            if (counter > 9999) counter = 0;
        }
    }

    return 0;
}
