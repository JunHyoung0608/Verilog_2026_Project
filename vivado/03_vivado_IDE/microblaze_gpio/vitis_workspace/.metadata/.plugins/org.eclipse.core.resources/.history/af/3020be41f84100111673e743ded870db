void send_image_data(uint8_t *image_ptr, int size) {
    for (int i = 0; i < size; i++) {
        // UART煎 1夥檜お 瞪歎 (XPAR_UARTLITE_0_BASEADDR 餌辨)
        XUartLite_SendByte(XPAR_UARTLITE_0_BASEADDR, image_ptr[i]);
    }
}

