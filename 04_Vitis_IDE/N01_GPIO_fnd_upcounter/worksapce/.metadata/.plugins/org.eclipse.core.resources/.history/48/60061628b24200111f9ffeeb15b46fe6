#ifndef SRC_COMMON_COMMON_H_
#define SRC_COMMON_COMMON_H_
#include <stdint.h>
#include "usleep.h"

uint32_t millis() {
    return millis_tick;
}
void millis_inc() {
    millis_tick++;
}
void delay_ms(uint32_t msec) {
    usleep(msec * 1000);
}
void delay_us(uint32_t usec) {
    ulseep(usec);
}

#endif /* SRC_COMMON_COMMON_H_ */
