#include <stdint.h>

#include "HAL/GPIO/GPIO.h"
#include "sleep.h"
#include "xil_printf.h"
#include "xparameters.h"

int main() {
    GPIOA->CR = 0x00;
    GPIOB->CR = 0xff;
    GPIOC->CR = 0xff;

    GPIO_SetMode(GPIOA, GPIO_PIN_0 | GPIO_PIN_1 | GPIO_PIN_2 | GPIO_PIN_3 | GPIO_PIN_4 | GPIO_PIN_5 | GPIO_PIN_6 | GPIO_PIN_7, INPUT);
    GPIO_SetMode(GPIOB, GPIO_PIN_0 | GPIO_PIN_1 | GPIO_PIN_2 | GPIO_PIN_3 | GPIO_PIN_4 | GPIO_PIN_5 | GPIO_PIN_6 | GPIO_PIN_7, OUTPUT);
    GPIO_SetMode(GPIOC, GPIO_PIN_0 | GPIO_PIN_1 | GPIO_PIN_2 | GPIO_PIN_3 | GPIO_PIN_4 | GPIO_PIN_5 | GPIO_PIN_6 | GPIO_PIN_7, OUTPUT);

    while (1) {
        GPIO_WritePort(GPIOB, 0x00);

        if (GPIO_ReadPin(GPIOA, GPIO_PIN_0)) {
            GPIO_WritePin(GPIOC, GPIO_PIN_0, RESET);
        } else if (GPIO_ReadPin(GPIOA, GPIO_PIN_1)) {
            GPIO_WritePin(GPIOC, GPIO_PIN_1, RESET);
        } else if (GPIO_ReadPin(GPIOA, GPIO_PIN_2)) {
            GPIO_WritePin(GPIOC, GPIO_PIN_2, RESET);
        } else if (GPIO_ReadPin(GPIOA, GPIO_PIN_3)) {
            GPIO_WritePin(GPIOC, GPIO_PIN_3, RESET);
        } else {
            GPIOC->ODR |= 0xf;
            GPIO_WritePin(GPIOC, GPIO_PIN_0 | GPIO_PIN_1 | GPIO_PIN_2 | GPIO_PIN_3, SET);
        }
    }
}
